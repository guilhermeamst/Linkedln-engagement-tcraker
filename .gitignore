# =============================================================================
# .gitignore - LinkedIn Engagement Tracker
# =============================================================================

# Credenciais e configuração local (NUNCA versionar)
.env
*.env.local

# Banco de dados SQLite
*.sqlite
*.sqlite3
*.db-shm
*.db-wal
# O arquivo principal do tracker é versionado intencionalmente (necessário para Streamlit Cloud)
# *.db  <-- mantido no repo

# Logs
logs/
*.log

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environment
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.virtualenv/

# IDE e editores
.idea/
.vscode/
*.swp
*.swo
*.orig
.DS_Store
Thumbs.db

# Pytest
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# Jupyter (se usado para análise)
.ipynb_checkpoints/

# Playwright
playwright-report/
test-results/

# Screenshots e downloads do scraper
screenshots/
downloads/

# Arquivos temporários
*.tmp
*.bak
*.backup
