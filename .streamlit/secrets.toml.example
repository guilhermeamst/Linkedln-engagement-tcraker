# Exemplo de configuração para Streamlit Cloud
# Copie o conteúdo abaixo para: App Settings > Secrets no Streamlit Cloud
# NÃO versione o secrets.toml real — somente este exemplo

# Caminho do banco de dados (opcional, padrão: linkedin_engagement.db)
DB_PATH = "linkedin_engagement.db"

# Credenciais LinkedIn (necessárias apenas para o scraper, não para o dashboard)
LINKEDIN_EMAIL = "seu_email@empresa.com"
LINKEDIN_PASSWORD = "sua_senha"
LINKEDIN_COMPANY_URL = "https://www.linkedin.com/company/sua-empresa"
