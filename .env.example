# =============================================================================
# LinkedIn Engagement Tracker - Configuração de Ambiente
# =============================================================================
# INSTRUÇÕES:
#   1. Copie este arquivo para .env na raiz do projeto:
#      cp .env.example .env
#   2. Preencha as variáveis abaixo com seus dados reais.
#   3. NUNCA faça commit do arquivo .env (ele já está no .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# CREDENCIAIS LINKEDIN (obrigatório)
# -----------------------------------------------------------------------------

# Email da conta pessoal LinkedIn usada para fazer login
LINKEDIN_EMAIL=seu_email@empresa.com.br

# Senha da conta LinkedIn
LINKEDIN_PASSWORD=sua_senha_aqui

# URL da página da empresa no LinkedIn
# Exemplo: https://www.linkedin.com/company/nome-da-empresa/
LINKEDIN_COMPANY_URL=https://www.linkedin.com/company/sua-empresa/

# -----------------------------------------------------------------------------
# BANCO DE DADOS
# -----------------------------------------------------------------------------

# Caminho do arquivo SQLite (relativo à raiz do projeto)
# Padrão: linkedin_engagement.db
DB_PATH=linkedin_engagement.db

# -----------------------------------------------------------------------------
# CONFIGURAÇÕES DO BROWSER
# -----------------------------------------------------------------------------

# Rodar browser em modo headless (sem interface visual)?
# true  = roda em background (recomendado para produção)
# false = exibe o browser (útil para debug e resolver captchas)
BROWSER_HEADLESS=true

# Delay em milissegundos entre ações do browser (simula comportamento humano)
# Valores maiores = mais lento, mas menos chance de detecção
# Recomendado: 50-200
BROWSER_SLOW_MO_MS=100

# -----------------------------------------------------------------------------
# CONFIGURAÇÕES DO SCRAPER
# -----------------------------------------------------------------------------

# Data de início da coleta (formato: YYYY-MM-DD)
# Apenas posts a partir desta data serão coletados
SCRAPER_DATA_INICIO=2026-01-06

# Número máximo de posts a processar por execução
# Recomendado: começar com valores pequenos (50-100) para testar
SCRAPER_MAX_POSTS=200

# Timeout em milissegundos para aguardar elementos na página
SCRAPER_WAIT_TIMEOUT_MS=30000

# Número de tentativas em caso de falha
SCRAPER_RETRY_ATTEMPTS=3

# Delay (em segundos) entre processamento de posts
# Valores muito baixos aumentam risco de bloqueio pelo LinkedIn
# Recomendado: 2.0 - 5.0 segundos
SCRAPER_DELAY_POSTS_S=2.5

# Delay (em segundos) entre carregamento de páginas
SCRAPER_DELAY_PAGES_S=2.0
